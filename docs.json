{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dancity",
  "colors": {
    "primary": "#074DEB",
    "light": "#4A7AFF",
    "dark": "#00144C"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://dancity.app"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index", "guides/quickstart"]
          },
          {
            "group": "Integration",
            "pages": [
              "guides/authentication",
              "guides/errors",
              "guides/rate-limits",
              "guides/webhook"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "VAS Services",
            "pages": [
              "api-reference/airtime",
              "api-reference/data",
              "api-reference/electricity",
              "api-reference/cable"
            ]
          },
          {
            "group": "Wallet & Transactions",
            "pages": ["api-reference/wallet", "api-reference/transactions"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://dancity.app",
          "icon": "house"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@dancity.app",
          "icon": "envelope"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "twitter": "https://twitter.com/dancityapp",
      "instagram": "https://instagram.com/dancityapp"
    }
  }
}
